    {
      "parameters": {
        "jsCode": "const input = $input.first().json.data;\nconst tasks = Array.isArray(input) ? input : [input];\n\nconst formatted = tasks.map(t => ({\n  name: t.name,\n  status: t.status?.status,\n  assignee: t.assignees?.map(a => a.username).join(', ') || 'Unassigned',\n  due_date: t.due_date ? new Date(+t.due_date).toISOString().split('T')[0] : 'No due date',\n  description: (t.text_content || t.description || '').slice(0, 200),\n  overdue: t.due_date ? +t.due_date < Date.now() : false\n}));\n\nconst today = new Date().toISOString().split('T')[0];\n\nreturn [{\n  json: {\n    prompt: `Today is ${today}. Here are the tasks:\\n\\n${JSON.stringify(formatted, null, 2)}`\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
